# =============================================================================
# ZAM Context Governance API — .dockerignore
#
# Excludes files from the Docker build context to:
#   - Reduce build time and context transfer size
#   - Prevent sensitive files from being accidentally included in the image
#   - Ensure the production image never contains source code or test artifacts
#
# Canonical: docs/31_PRODUCT_DISTRIBUTION_AND_PACKAGING.md §3 DQ-9.
# =============================================================================

# Dependencies (installed fresh inside the container)
node_modules/

# Compiled output (rebuilt from source in the builder stage)
dist/

# Test infrastructure
tests/
fixtures/
fixtures-future/

# Schema sources (compiled into JS via AJV — not read from disk at runtime)
schemas/

# Development and research
docs/
evaluations/
scratch/
specs/

# Runtime session data and SDK package (not part of the server image)
sessions/
test-sessions/
packages/

# Build artifacts and log files
coverage/
*.tsbuildinfo
*.txt
failed_fixture_log*.txt
harness-*.txt
scratch-output.txt
temp_log.txt

# Environment files — NEVER bake secrets into the image
.env
.env.*

# Generated CLI outputs
prompt-plan.json
trace.json
summary.md

# Scratch and temporary files
scratch-*.cjs
scratch-*.ts

# Git
.git/
.gitignore

# Editor and OS artifacts
.DS_Store
Thumbs.db
*.swp
