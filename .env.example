# ZAM Context Governance — HTTP service environment configuration
# Copy this file to .env and fill in the values. NEVER commit .env.

# ─── Server ──────────────────────────────────────────────────────────────────

# Port the HTTP service listens on (default: 3000)
ZAM_PORT=3000

# Host interface to bind (default: 127.0.0.1). Set to 0.0.0.0 to accept
# non-local connections — only together with ZAM_API_KEY below.
ZAM_HOST=127.0.0.1

# Log level: trace | debug | info | warn | error | fatal | silent
ZAM_LOG_LEVEL=info

# ─── Authentication ──────────────────────────────────────────────────────────

# API key for the X-ZAM-API-Key header. REQUIRED for any non-local deployment.
# If unset, the service accepts all requests (local-only mode).
# Generate a strong random key:  openssl rand -hex 32
ZAM_API_KEY=
