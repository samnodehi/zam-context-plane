node_modules/
dist/
dist-standalone/
coverage/
.env
.env.*
# .env.example is the committed template — keep it tracked despite .env.* above
!.env.example
*.js.map
*.tsbuildinfo

# Generated, bundler-safe schema/version modules (scripts/gen-embedded-schemas.mjs;
# regenerated in prepare/pretest/build). Source of truth: schemas/ + package.json.
src/generated/

# Claude Code machine-local settings (per-machine permissions; not shared)
.claude/settings.local.json

# Google Drive sync temp dirs (this workspace is Drive-synced; git is source of truth)
.tmp.drivedownload/
.tmp.driveupload/

# Generated CLI outputs (context-plane plan with default --output-dir)
/prompt-plan.json
/trace.json
/summary.md

# Live benchmark output is non-deterministic (real model calls) — do not track.
# (The offline benchmarks/report.json IS deterministic and committed.)
benchmarks/live-report.json

# Scratch / temporary files
scratch/
# Throwaway dir for verifying published npm tarballs (npm pack extraction)
.verify-pub/

# Ad-hoc test artifacts (evaluations/ itself is committable for intentional reports)
evaluations/scratch/

# Runtime local config and EventStream session logs (contain credentials and ephemeral data)
runtime.config.json
sessions/
test-sessions/

# Ad-hoc scratch / log artifacts at repo root (root-anchored so legit subdir files are unaffected)
/failed_fixture_log*.txt
/harness-*.txt
/temp_log.txt
/scratch-output.txt
/scratch-*.cjs
