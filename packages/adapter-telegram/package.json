{
  "name": "zam-adapter-telegram",
  "version": "0.1.0",
  "description": "Reference adapter: governs a Telegram bot's per-message context via the ZAM context plane, deriving requestSignals from update metadata (chat type, reply).",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Sam Noodehi",
  "homepage": "https://github.com/samnodehi/zam-context-plane/tree/main/packages/adapter-telegram#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samnodehi/zam-context-plane.git",
    "directory": "packages/adapter-telegram"
  },
  "bugs": {
    "url": "https://github.com/samnodehi/zam-context-plane/issues"
  },
  "keywords": [
    "zam",
    "context-plane",
    "context-governance",
    "ai-agents",
    "adapter",
    "telegram",
    "bot"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "zam-telegram": "./dist/cli.js"
  },
  "files": [
    "dist",
    "example-bot.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "context-plane": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
