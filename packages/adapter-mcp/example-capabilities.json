{
  "servers": [
    {
      "name": "filesystem",
      "tools": [
        {
          "name": "read_file",
          "description": "Read the contents of a file from the workspace.",
          "inputSchema": { "type": "object", "properties": { "path": { "type": "string" } }, "required": ["path"] },
          "annotations": { "readOnlyHint": true }
        },
        {
          "name": "list_dir",
          "description": "List the entries in a directory.",
          "inputSchema": { "type": "object", "properties": { "path": { "type": "string" } } },
          "annotations": { "readOnlyHint": true }
        },
        {
          "name": "edit_file",
          "description": "Apply an edit to a source code file.",
          "inputSchema": { "type": "object", "properties": { "path": { "type": "string" }, "patch": { "type": "string" } } }
        },
        {
          "name": "write_file",
          "description": "Overwrite a file with new contents.",
          "inputSchema": { "type": "object", "properties": { "path": { "type": "string" }, "content": { "type": "string" } } },
          "annotations": { "destructiveHint": true }
        }
      ],
      "resources": [
        {
          "uri": "file:///README.md",
          "name": "project_readme",
          "description": "The project README and overview.",
          "mimeType": "text/markdown"
        }
      ],
      "prompts": [
        {
          "name": "code_review",
          "description": "Review code changes for bugs and style.",
          "arguments": [{ "name": "diff", "required": true }]
        }
      ]
    },
    {
      "name": "web",
      "tools": [
        {
          "name": "web_search",
          "description": "Search the web and return ranked results.",
          "inputSchema": { "type": "object", "properties": { "query": { "type": "string" } } },
          "annotations": { "readOnlyHint": true, "openWorldHint": true }
        },
        {
          "name": "fetch_url",
          "description": "Fetch and return the contents of a URL.",
          "inputSchema": { "type": "object", "properties": { "url": { "type": "string" } } },
          "annotations": { "readOnlyHint": true }
        }
      ],
      "prompts": [
        {
          "name": "research_summary",
          "description": "Summarize research findings from multiple sources."
        }
      ]
    },
    {
      "name": "shell",
      "tools": [
        {
          "name": "run_command",
          "description": "Execute a shell command in the workspace.",
          "inputSchema": { "type": "object", "properties": { "command": { "type": "string" } } },
          "annotations": { "destructiveHint": true, "openWorldHint": true }
        },
        {
          "name": "kill_process",
          "description": "Terminate a running process by PID.",
          "inputSchema": { "type": "object", "properties": { "pid": { "type": "number" } } },
          "annotations": { "destructiveHint": true }
        }
      ]
    },
    {
      "name": "database",
      "tools": [
        {
          "name": "query_db",
          "description": "Run a read-only SQL query against the database.",
          "inputSchema": { "type": "object", "properties": { "sql": { "type": "string" } } },
          "annotations": { "readOnlyHint": true }
        },
        {
          "name": "drop_table",
          "description": "Drop a database table.",
          "inputSchema": { "type": "object", "properties": { "table": { "type": "string" } } },
          "annotations": { "destructiveHint": true }
        }
      ],
      "resources": [
        {
          "uri": "db://schema",
          "name": "db_schema",
          "description": "The current database schema definition."
        }
      ]
    }
  ]
}
