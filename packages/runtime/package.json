{
  "name": "@zam/runtime",
  "version": "0.1.0",
  "description": "ZAM-Native Agent Runtime — lightweight loop owner consuming ZAM context governance",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
